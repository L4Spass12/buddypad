---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';
import { unsplashSrcset, unsplashAt } from '../lib/image';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<section id="blog" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
      <div>
        <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-cream mb-2">Derniers articles</h2>
        <p class="text-sm text-n-500 font-light">Tests, guides et inspirations setup.</p>
      </div>
      <a href="/blog" class="hidden md:inline-flex items-center gap-2 text-sm text-n-400 hover:text-cream transition-colors">
        Voir tous les articles →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {posts.map((post) => (
        <a href={`/${post.slug}`} class="group block">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-panel border border-white/[0.05] mb-5">
            {post.data.image
              ? <img
                  src={unsplashAt(post.data.image, 600)}
                  srcset={unsplashSrcset(post.data.image, [400, 600, 800])}
                  sizes="(max-width: 768px) calc(100vw - 32px), (max-width: 1024px) calc(50vw - 48px), 380px"
                  alt={post.data.imageAlt ?? post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500"
                  width="800" height="600" loading="lazy"
                />
              : <div class="w-full h-full flex items-center justify-center text-n-500"><Icon name="mouse" size={48} strokeWidth={1.25} /></div>
            }
            {post.data.featured && (
              <div class="absolute top-4 left-4">
                <span class="bg-cream text-dark text-[10px] font-medium px-2 py-1 rounded-sm uppercase tracking-wider">À la une</span>
              </div>
            )}
          </div>
          <div class="flex flex-col">
            <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-2">{post.data.category}</span>
            <h3 class="text-base font-medium text-cream mb-1 tracking-tight leading-snug group-hover:underline underline-offset-4">
              {post.data.title}
            </h3>
            <p class="text-xs text-n-500 font-light line-clamp-2 mt-1">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="text-[11px] text-n-500 font-light mt-3">{formatDate(post.data.pubDate)}</time>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10 md:hidden">
      <a href="/blog" class="btn-primary">Voir tous les articles</a>
    </div>
  </div>
</section>
