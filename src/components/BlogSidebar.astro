---
import type { MarkdownHeading } from 'astro';
import Icon from './Icon.astro';
import siteConfig from '../../site.config.mjs';

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2);
---

<!-- ── Desktop sidebar (lg+) ── -->
<aside class="hidden lg:block lg:sticky lg:top-24 lg:self-start space-y-6">

  {toc.length > 0 && (
    <nav aria-label="Sommaire">
      <p class="text-[10px] font-medium uppercase tracking-widest text-n-500 mb-4">Sommaire</p>
      <ul class="space-y-0.5 border-l border-white/[0.08]">
        {toc.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class="toc-link block text-sm text-n-400 hover:text-cream transition-colors leading-snug py-1.5 pl-4 -ml-px border-l border-transparent truncate font-light"
              title={h.text}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <!-- CTA -->
  <div class="rounded-2xl p-6 border border-white/[0.08] bg-panel">
    <p class="text-[10px] font-medium uppercase tracking-widest text-n-500 mb-3">Boutique</p>
    <h3 class="text-base font-medium text-cream tracking-tight leading-tight mb-3">
      Le tapis parfait pour votre setup.
    </h3>
    <p class="text-xs text-n-500 font-light leading-relaxed mb-5">
      Notre sélection, testée et notée.
    </p>
    <a href="/boutique" class="btn-primary w-full text-xs py-2.5">
      Voir la boutique
    </a>
  </div>

  <!-- Share -->
  <div>
    <p class="text-[10px] font-medium uppercase tracking-widest text-n-500 mb-3">Partager</p>
    <div class="flex gap-2">
      <button data-share="twitter" aria-label="Partager sur X" class="share-btn w-8 h-8 rounded-full border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20 flex items-center justify-center transition-colors">
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </button>
      <button data-share="facebook" aria-label="Partager sur Facebook" class="share-btn w-8 h-8 rounded-full border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20 flex items-center justify-center transition-colors">
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </button>
      <button data-share="copy" aria-label="Copier le lien" class="share-btn w-8 h-8 rounded-full border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20 flex items-center justify-center transition-colors">
        <svg class="w-3.5 h-3.5 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
      </button>
    </div>
  </div>
</aside>


<!-- ── Mobile FAB (< lg) ── -->
{toc.length > 0 && (
  <div class="lg:hidden">

    <!-- FAB button -->
    <button
      id="toc-fab"
      aria-label="Plan de l'article"
      aria-expanded="false"
      aria-controls="toc-sheet"
      class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40
             flex items-center gap-2
             bg-teal text-cream
             pl-4 pr-5 py-3
             rounded-full shadow-xl
             font-body text-sm font-semibold
             transition-all duration-200
             hover:bg-terracotta/90 active:scale-95"
    >
      <!-- Animated hamburger / close icon -->
      <span id="fab-icon" class="relative w-5 h-5 flex-shrink-0">
        <svg class="fab-lines absolute inset-0 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 20 20">
          <line x1="3" y1="6" x2="17" y2="6" />
          <line x1="3" y1="10" x2="12" y2="10" />
          <line x1="3" y1="14" x2="17" y2="14" />
        </svg>
        <svg class="fab-close absolute inset-0 transition-all duration-200 opacity-0 scale-75" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 20 20">
          <line x1="4" y1="4" x2="16" y2="16" />
          <line x1="16" y1="4" x2="4" y2="16" />
        </svg>
      </span>
      <span id="fab-label">Plan de l'article</span>
      <span class="ml-1 bg-dark/20 text-cream text-xs px-1.5 py-0.5 rounded-full font-bold">
        {toc.length}
      </span>
    </button>

    <!-- Backdrop -->
    <div
      id="toc-backdrop"
      class="fixed inset-0 z-40 bg-dark/50 backdrop-blur-sm
             opacity-0 pointer-events-none
             transition-opacity duration-300 ease-out"
    ></div>

    <!-- Bottom sheet -->
    <div
      id="toc-sheet"
      role="dialog"
      aria-modal="true"
      aria-label="Plan de l'article"
      class="fixed inset-x-0 bottom-0 z-50
             bg-dark rounded-t-3xl shadow-2xl
             translate-y-full
             transition-transform duration-350 ease-[cubic-bezier(0.32,0.72,0,1)]
             max-h-[75vh] flex flex-col"
    >
      <!-- Handle -->
      <div class="flex justify-center pt-3 pb-1 flex-shrink-0">
        <div class="w-10 h-1 rounded-full bg-dark/20"></div>
      </div>

      <!-- Header -->
      <div class="flex items-center justify-between px-6 pt-2 pb-4 flex-shrink-0 border-b border-beige">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-lg bg-teal/10 text-terracotta flex items-center justify-center">
            <svg fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 20 20" class="w-4 h-4">
              <line x1="3" y1="5" x2="17" y2="5" />
              <line x1="3" y1="9" x2="12" y2="9" />
              <line x1="3" y1="13" x2="17" y2="13" />
            </svg>
          </div>
          <span class="font-body font-bold text-cream text-sm">Plan de l'article</span>
        </div>
        <button id="toc-close" aria-label="Fermer" class="w-8 h-8 rounded-full bg-beige flex items-center justify-center text-cream/60 hover:bg-terracotta hover:text-cream transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 16 16">
            <line x1="3" y1="3" x2="13" y2="13" /><line x1="13" y1="3" x2="3" y2="13" />
          </svg>
        </button>
      </div>

      <!-- TOC list (scrollable) -->
      <nav class="overflow-y-auto flex-1 px-6 py-4">
        <ul class="space-y-1">
          {toc.map((h, i) => (
            <li>
              <a
                href={`#${h.slug}`}
                data-toc-link={h.slug}
                data-mobile-toc
                class="toc-link flex items-center gap-3 font-body text-sm text-cream/70 py-3 border-b border-beige/60 last:border-0 active:text-terracotta"
              >
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-beige text-terracotta font-bold text-xs flex items-center justify-center">
                  {i + 1}
                </span>
                <span>{h.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Sheet footer: CTA + share -->
      <div class="px-6 py-4 flex-shrink-0 border-t border-beige bg-panel rounded-t-none">
        <a href="/boutique" class="btn-primary w-full justify-center text-sm mb-3">
          <Icon name="cart" size={18} strokeWidth={1.75} />
          {siteConfig.article.cta}
        </a>
        <div class="flex justify-center gap-3">
          <button data-share="twitter" aria-label="X" class="share-btn w-9 h-9 rounded-full bg-beige text-cream/60 hover:bg-terracotta hover:text-cream flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button data-share="facebook" aria-label="Facebook" class="share-btn w-9 h-9 rounded-full bg-beige text-cream/60 hover:bg-terracotta hover:text-cream flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </button>
          <button data-share="copy" aria-label="Copier le lien" class="share-btn w-9 h-9 rounded-full bg-beige text-cream/60 hover:bg-terracotta hover:text-cream flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
)}

<style>
  #toc-sheet { transition-duration: 350ms; }
  #toc-sheet.open { transform: translateY(0); }
  #toc-backdrop.open { opacity: 1; pointer-events: auto; }

  /* FAB open state icon swap */
  #toc-fab.open .fab-lines { opacity: 0; transform: scale(0.75); }
  #toc-fab.open .fab-close { opacity: 1; transform: scale(1); }
</style>

<script>
  // ── Intersection Observer for active TOC link (desktop + mobile) ──
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  const sections = Array.from(tocLinks).reduce<HTMLElement[]>((acc, link) => {
    const id = link.dataset.tocLink;
    const el = id ? document.getElementById(id) : null;
    if (el && !acc.includes(el)) acc.push(el);
    return acc;
  }, []);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.id;
      tocLinks.forEach(link => {
        const active = link.dataset.tocLink === id;
        link.classList.toggle('text-cream', active);
        link.classList.toggle('border-cream', active);
        link.classList.toggle('font-medium', active);
        link.classList.toggle('text-n-400', !active);
        link.classList.toggle('border-transparent', !active);
      });
    });
  }, { rootMargin: '-80px 0px -60% 0px' });

  sections.forEach(el => observer.observe(el));

  // ── Mobile bottom sheet ──
  const fab     = document.getElementById('toc-fab');
  const sheet   = document.getElementById('toc-sheet');
  const backdrop = document.getElementById('toc-backdrop');
  const closeBtn = document.getElementById('toc-close');

  function openSheet() {
    sheet?.classList.add('open');
    backdrop?.classList.add('open');
    fab?.classList.add('open');
    fab?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    sheet?.classList.remove('open');
    backdrop?.classList.remove('open');
    fab?.classList.remove('open');
    fab?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  fab?.addEventListener('click', () => {
    sheet?.classList.contains('open') ? closeSheet() : openSheet();
  });

  backdrop?.addEventListener('click', closeSheet);
  closeBtn?.addEventListener('click', closeSheet);

  // Close sheet when a TOC link is clicked
  document.querySelectorAll('[data-mobile-toc]').forEach(link => {
    link.addEventListener('click', () => setTimeout(closeSheet, 120));
  });

  // Swipe down to close
  let touchStartY = 0;
  sheet?.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });
  sheet?.addEventListener('touchend', (e) => {
    if (e.changedTouches[0].clientY - touchStartY > 60) closeSheet();
  }, { passive: true });

  // ESC key
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSheet(); });

  // ── Share buttons ──
  document.querySelectorAll<HTMLButtonElement>('[data-share]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = window.location.href;
      const title = document.title;
      const type = btn.dataset.share;
      if (type === 'twitter') {
        window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`, '_blank');
      } else if (type === 'facebook') {
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank');
      } else if (type === 'copy') {
        await navigator.clipboard.writeText(url);
        btn.classList.add('!bg-terracotta', '!text-cream');
        setTimeout(() => btn.classList.remove('!bg-terracotta', '!text-cream'), 1500);
      }
    });
  });
</script>
