---
// Section "Fabrication Haute Précision" — réutilisable sur toutes les fiches produit.
// Reproduit la section présente sur buddypad.com (WP) en mode Astro full static.

interface Props {
  /** Points clés affichés à droite (par défaut : 3 items standards). */
  bullets?: string[];
  /** Surtitre affiché au-dessus du H2. */
  eyebrow?: string;
  /** Titre principal. */
  title?: string;
}

const {
  eyebrow = 'Performance & Durabilité',
  title = 'Fabrication Haute Précision',
  bullets = [
    'Qualité de glisse supérieure',
    'Finition parfaite & durable',
    'Résistance optimale',
  ],
} = Astro.props;
---

<section class="relative py-20 md:py-28 px-6 border-t border-white/[0.04] overflow-hidden bg-gradient-to-br from-[#0a0f1f] via-[#0c0e14] to-dark">
  <!-- Grille subtile bleutée en arrière-plan (effet tech/industriel) -->
  <div
    class="absolute inset-0 opacity-[0.08] pointer-events-none"
    style="background-image: linear-gradient(rgba(80,120,255,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(80,120,255,0.2) 1px, transparent 1px); background-size: 48px 48px;"
  ></div>
  <!-- Glow bleu pour souligner l'ambiance atelier -->
  <div class="absolute top-1/2 right-10 -translate-y-1/2 w-[500px] h-[400px] bg-[#3b5bff]/[0.10] blur-[140px] rounded-full pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto grid md:grid-cols-2 gap-10 md:gap-14 items-center">
    <!-- Image machine -->
    <div class="relative">
      <div class="relative rounded-2xl overflow-hidden border border-white/[0.06] bg-dark aspect-[4/3]">
        <img
          src="/images/about/fabrication.webp"
          srcset="/images/about/fabrication-400w.webp 400w, /images/about/fabrication-800w.webp 800w, /images/about/fabrication.webp 1536w"
          sizes="(max-width: 768px) 100vw, 500px"
          alt="Presse à chaud professionnelle fabriquant un tapis de souris BuddyPad"
          class="w-full h-full object-cover"
          width="1536"
          height="1024"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Contenu -->
    <div>
      <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-3 block">
        {eyebrow}
      </span>
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-medium tracking-tight text-cream mb-8 leading-[1.15]">
        {title}
      </h2>
      <ul class="space-y-4">
        {bullets.map(b => (
          <li class="flex items-center gap-3">
            <span class="w-6 h-6 rounded-full bg-white/[0.04] border border-white/[0.12] flex items-center justify-center text-cream shrink-0">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span class="text-sm md:text-base text-n-300 font-light">{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
