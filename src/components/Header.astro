---
import siteConfig from '../../site.config.mjs';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 backdrop-blur-xl bg-dark/80 border-b border-white/[0.08]"
  style="height: var(--header-h); z-index: 10000;"
>
  <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">
    <a href="/" class="font-medium tracking-tightest text-lg text-cream" aria-label={`${siteConfig.name} – accueil`}>
      {siteConfig.logoPrefix}<span class="text-n-400">{siteConfig.logoSuffix}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6 font-body text-sm text-n-400">
      <a href="/" class="hover:text-cream transition-colors">Accueil</a>
      <a href="/blog" class="hover:text-cream transition-colors">Blog</a>
      {siteConfig.shop?.enabled && <a href="/boutique" class="hover:text-cream transition-colors">Boutique</a>}
      <a href="/#a-propos" class="hover:text-cream transition-colors">À propos</a>
    </nav>

    <div class="flex items-center gap-5">
      {siteConfig.shop?.enabled && siteConfig.shop?.provider === 'snipcart' && (
        <button class="snipcart-checkout text-n-400 hover:text-cream transition-colors inline-flex items-center justify-center relative" aria-label="Voir le panier">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="snipcart-items-count absolute -top-1.5 -right-1.5 flex min-w-[14px] h-[14px] items-center justify-center rounded-full bg-cream text-dark text-[10px] font-medium leading-none px-1"></span>
        </button>
      )}

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="md:hidden text-n-400 hover:text-cream transition-colors flex items-center justify-center"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="hidden md:hidden bg-dark border-t border-white/[0.08] px-6 py-4 flex-col gap-2 font-body text-sm"
  >
    <a href="/" class="block py-2 text-n-400 hover:text-cream transition-colors">Accueil</a>
    <a href="/blog" class="block py-2 text-n-400 hover:text-cream transition-colors">Blog</a>
    {siteConfig.shop?.enabled && <a href="/boutique" class="block py-2 text-n-400 hover:text-cream transition-colors">Boutique</a>}
    <a href="/#a-propos" class="block py-2 text-n-400 hover:text-cream transition-colors">À propos</a>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('mobile-nav');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden', isOpen);
    nav?.classList.toggle('flex', !isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
