---
import type { IconName } from './icons';

interface Props {
  name: IconName;
  class?: string;
  size?: number | string;
  strokeWidth?: number;
  fill?: boolean;
}
const {
  name,
  class: className = '',
  size = 24,
  strokeWidth = 1.75,
  fill = false,
} = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={fill ? 'currentColor' : 'none'}
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === 'mouse' && (
    <>
      <rect x="6" y="2" width="12" height="20" rx="6" />
      <line x1="12" y1="2" x2="12" y2="11" />
    </>
  )}

  {name === 'keyboard' && (
    <>
      <rect x="2" y="6" width="20" height="12" rx="2" />
      <line x1="6" y1="10" x2="6" y2="10.01" />
      <line x1="10" y1="10" x2="10" y2="10.01" />
      <line x1="14" y1="10" x2="14" y2="10.01" />
      <line x1="18" y1="10" x2="18" y2="10.01" />
      <line x1="8" y1="14" x2="16" y2="14" />
    </>
  )}

  {name === 'monitor' && (
    <>
      <rect x="2" y="3" width="20" height="14" rx="2" />
      <line x1="8" y1="21" x2="16" y2="21" />
      <line x1="12" y1="17" x2="12" y2="21" />
    </>
  )}

  {name === 'headphones' && (
    <>
      <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
      <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" />
    </>
  )}

  {name === 'gamepad' && (
    <>
      <line x1="6" y1="11" x2="10" y2="11" />
      <line x1="8" y1="9" x2="8" y2="13" />
      <line x1="15" y1="12" x2="15.01" y2="12" />
      <line x1="18" y1="10" x2="18.01" y2="10" />
      <path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59L2.033 15.5A3 3 0 0 0 5.02 19a3 3 0 0 0 2.684-1.658L8.5 16h7l.796 1.342A3 3 0 0 0 18.98 19a3 3 0 0 0 2.987-3.5l-.669-6.91A4 4 0 0 0 17.32 5z" />
    </>
  )}

  {name === 'cpu' && (
    <>
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <rect x="9" y="9" width="6" height="6" />
      <line x1="9" y1="2" x2="9" y2="4" />
      <line x1="15" y1="2" x2="15" y2="4" />
      <line x1="9" y1="20" x2="9" y2="22" />
      <line x1="15" y1="20" x2="15" y2="22" />
      <line x1="20" y1="9" x2="22" y2="9" />
      <line x1="20" y1="15" x2="22" y2="15" />
      <line x1="2" y1="9" x2="4" y2="9" />
      <line x1="2" y1="15" x2="4" y2="15" />
    </>
  )}

  {name === 'rgb' && (
    <>
      <circle cx="8" cy="12" r="5" />
      <circle cx="16" cy="12" r="5" />
      <circle cx="12" cy="8" r="5" />
    </>
  )}

  {name === 'desk' && (
    <>
      <line x1="3" y1="10" x2="21" y2="10" />
      <line x1="5" y1="10" x2="5" y2="20" />
      <line x1="19" y1="10" x2="19" y2="20" />
      <line x1="8" y1="14" x2="8" y2="20" />
      <line x1="16" y1="14" x2="16" y2="20" />
      <path d="M3 10l2-5h14l2 5" />
    </>
  )}

  {name === 'cart' && (
    <>
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
      <path d="M3 6h18" />
      <path d="M16 10a4 4 0 0 1-8 0" />
    </>
  )}

  {name === 'heart' && (
    <path d="M12 20.5s-7.5-4.7-7.5-10.2a4.3 4.3 0 0 1 7.5-2.9 4.3 4.3 0 0 1 7.5 2.9c0 5.5-7.5 10.2-7.5 10.2z" />
  )}

  {name === 'star' && (
    <path d="M12 2.5l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6-5.9-3.3-5.9 3.3 1.2-6.6L2.5 9.5l6.6-.9z" />
  )}

  {name === 'sparkle' && (
    <>
      <path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z" />
      <path d="M19 15l.9 2.1L22 18l-2.1.9L19 21l-.9-2.1L16 18l2.1-.9z" />
    </>
  )}

  {name === 'pen' && (
    <>
      <path d="M17 3l4 4-12 12H5v-4z" />
      <line x1="14" y1="6" x2="18" y2="10" />
    </>
  )}

  {name === 'arrow-right' && (
    <>
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12,5 19,12 12,19" />
    </>
  )}

  {name === 'bell' && (
    <>
      <path d="M6 9a6 6 0 0 1 12 0c0 7 3 8 3 8H3s3-1 3-8" />
      <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
    </>
  )}

  {name === 'lock' && (
    <>
      <rect x="4" y="11" width="16" height="10" rx="2" />
      <path d="M8 11V7a4 4 0 0 1 8 0v4" />
    </>
  )}

  {name === 'shield-check' && (
    <>
      <path d="M12 21s8-4 8-10V5l-8-2-8 2v6c0 6 8 10 8 10z" />
      <polyline points="9,12 11,14 15,10" />
    </>
  )}

  {name === 'check' && (
    <polyline points="4,12 10,18 20,6" />
  )}

  {name === 'bolt' && (
    <polygon points="13,2 3,14 12,14 11,22 21,10 12,10" />
  )}

  {name === 'ruler' && (
    <>
      <path d="M16 2l6 6-14 14-6-6z" />
      <line x1="7" y1="9" x2="9" y2="11" />
      <line x1="10" y1="6" x2="12" y2="8" />
      <line x1="13" y1="3" x2="15" y2="5" />
      <line x1="4" y1="12" x2="6" y2="14" />
      <line x1="7" y1="15" x2="9" y2="17" />
    </>
  )}
</svg>
