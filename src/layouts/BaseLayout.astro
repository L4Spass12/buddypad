---
import '../styles/global.css';
import siteConfig from '../../site.config.mjs';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  /** Additional JSON-LD block(s) to inject (object or array) */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_NAME = siteConfig.name;
const SITE_URL = siteConfig.url;
const DEFAULT_DESCRIPTION = siteConfig.description;

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = '/og-image.jpg',
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL);
const ogImage = new URL(image, Astro.site ?? SITE_URL).toString();

// Organization + WebSite structured data (always present)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  sameAs: Object.values(siteConfig.socials).filter(Boolean),
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const baseSchemas = [organizationSchema, websiteSchema];
const extraSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allSchemas = [...baseSchemas, ...extraSchemas];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0A0A0F" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#A855F7" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS feed discovery -->
    <link rel="alternate" type="application/rss+xml" title={`Blog ${SITE_NAME}`} href={`${SITE_URL}/rss.xml`} />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />


    <!-- Structured data (JSON-LD) -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {siteConfig.shop?.enabled && siteConfig.shop?.publicKey && (
      <>
        <style is:global set:html={`
          /* ───────────────────────────────────────────────────────────
             SNIPCART — DARK THEME (BuddyPad / GLIDE-style)
             CSS custom properties reconnues par Snipcart v3.7
             ─────────────────────────────────────────────────────────── */
          #snipcart {
            /* Textes */
            --color-default:                 #F4F4F7;   /* texte principal */
            --color-alt:                     #A3A3A3;   /* texte secondaire */
            --color-link:                    #F4F4F7;   /* liens */
            --color-link-hover:              #FFFFFF;
            --color-link-active:             #FFFFFF;

            /* Backgrounds */
            --bgColor-default:               #0A0A0A;   /* bg modal principal */
            --bgColor-alt:                   #0D0D0D;   /* bg panels/cards internes */

            /* Bordures */
            --borderColor-default:           rgba(255,255,255,0.08);
            --borderColor-alt:               rgba(255,255,255,0.08);

            /* Icônes (panier, flèches) */
            --color-icon:                    #F4F4F7;

            /* Badge (compteur, tags) */
            --color-badge:                   #0A0A0A;
            --bgColor-badge:                 #F4F4F7;

            /* Bouton primaire — blanc sur dark (GLIDE) */
            --color-buttonPrimary:           #0A0A0A;
            --color-buttonPrimary-hover:     #0A0A0A;
            --color-buttonPrimary-active:    #0A0A0A;
            --bgColor-buttonPrimary:         #F4F4F7;
            --bgColor-buttonPrimary-hover:   #E5E5E5;
            --bgColor-buttonPrimary-active:  #D4D4D4;
            --borderColor-buttonPrimary:     #F4F4F7;

            /* Bouton secondaire — ghost outline */
            --color-buttonSecondary:         #F4F4F7;
            --color-buttonSecondary-hover:   #F4F4F7;
            --color-buttonSecondary-active:  #F4F4F7;
            --bgColor-buttonSecondary:       transparent;
            --bgColor-buttonSecondary-hover: rgba(255,255,255,0.05);
            --bgColor-buttonSecondary-active:rgba(255,255,255,0.08);
            --borderColor-buttonSecondary:   rgba(255,255,255,0.12);

            /* Inputs — variables officielles Snipcart v3.7
               (toutes les variantes, y compris autofill qui par défaut
               est bleu clair #d9f0fc et écrase nos règles) */
            --color-input:                   #F4F4F7;
            --color-input-hover:             #F4F4F7;
            --color-input-focus:             #F4F4F7;
            --color-inputLabel:              #D4D4D8;
            --color-inputPlaceholder:        #525252;
            --color-inputIcon:               #A3A3A3;
            --color-inputIcon-hover:         #F4F4F7;
            --color-inputIcon-focus:         #F4F4F7;
            --bgColor-input:                 #141414;
            --bgColor-input-hover:           #1A1A1A;
            --bgColor-input-focus:           #1A1A1A;
            --bgColor-input-autofill:        #141414;
            --bgColor-inputLabel:            transparent;
            --borderColor-input:             rgba(255,255,255,0.08);
            --borderColor-input-hover:       rgba(255,255,255,0.2);
            --borderColor-input-focus:       rgba(255,255,255,0.35);
            --shadow-input-focus:            0 0 0 2px rgba(255,255,255,0.06);

            /* Erreurs */
            --color-error:                   #F87171;
            --color-success:                 #22C55E;
            --color-info:                    #A3A3A3;

            /* Divers */
            --borderRadius-s:                0.5rem;
            --borderRadius-m:                1rem;
            --borderRadius-l:                1.5rem;
            --font-body:                     'Inter', system-ui, sans-serif;
            --font-heading:                  'Inter', system-ui, sans-serif;
          }

          /* ───────────────────────────────────────────────────────────
             Snipcart v3.7 — dark theme
             Stratégie : bg TRANSPARENT par défaut (hérite du root dark),
             puis on restaure un bg dark uniquement sur les conteneurs
             racine. Évite d'imposer du noir aux enfants des boutons
             blancs (qui restent donc propres).
             ─────────────────────────────────────────────────────────── */

          /* Root : le SEUL endroit avec un vrai bg dark appliqué */
          #snipcart {
            background-color: #0A0A0A !important;
            color: #F4F4F7 !important;
          }

          /* Tout le reste : transparent, hérite du root */
          #snipcart [class^="snipcart-"],
          #snipcart [class*=" snipcart-"],
          #snipcart [class^="snipcart__"],
          #snipcart [class*=" snipcart__"] {
            background-color: transparent !important;
            color: #F4F4F7 !important;
            border-color: rgba(255,255,255,0.08) !important;
          }

          /* Backdrop derrière le modal */
          #snipcart .snipcart__backdrop,
          #snipcart .snipcart-modal__backdrop {
            background-color: rgba(0,0,0,0.7) !important;
          }

          /* Conteneurs racine — re-forcer le dark pour éviter les "trous"
             s'il y avait des bg blancs intermédiaires injectés par Snipcart */
          #snipcart .snipcart-modal,
          #snipcart .snipcart-modal__container,
          #snipcart .snipcart-layout,
          #snipcart .snipcart-layout__content,
          #snipcart .snipcart-layout__header,
          #snipcart .snipcart-cart,
          #snipcart .snipcart-cart__content,
          #snipcart .snipcart-cart__empty,
          #snipcart .snipcart-checkout,
          #snipcart .snipcart-checkout__content,
          #snipcart .snipcart__box {
            background-color: #0A0A0A !important;
          }

          /* Close button / back arrow / icons */
          #snipcart .snipcart-modal__close,
          #snipcart .snipcart-modal__close-icon,
          #snipcart .snipcart-modal__close-title,
          #snipcart .snipcart__icon,
          #snipcart [class*="snipcart__icon"],
          #snipcart svg {
            color: #F4F4F7 !important;
            fill: #F4F4F7 !important;
          }
          /* Le logo VISA/MasterCard etc. en bas — on garde leurs couleurs originales */
          #snipcart .snipcart-payment-method__logo svg,
          #snipcart .snipcart__actions--payment svg,
          #snipcart img {
            filter: none !important;
          }

          /* Typographie — toutes variantes */
          #snipcart h1, #snipcart h2, #snipcart h3, #snipcart h4,
          #snipcart p, #snipcart span, #snipcart label, #snipcart a,
          #snipcart strong, #snipcart em, #snipcart li,
          #snipcart [class*="snipcart-typography"],
          #snipcart [class*="snipcart__font"],
          #snipcart [class*="snipcart__title"],
          #snipcart [class*="snipcart__heading"],
          #snipcart [class*="snipcart__text"] {
            color: #F4F4F7 !important;
            font-family: 'Inter', system-ui, sans-serif !important;
            background-color: transparent !important;
          }
          #snipcart h1, #snipcart h2, #snipcart h3, #snipcart h4,
          #snipcart [class*="snipcart-typography--heading"],
          #snipcart [class*="snipcart-typography--title"] {
            font-weight: 500 !important;
            letter-spacing: -0.01em !important;
          }
          /* Texte secondaire (ex. "Quantité", "Les frais de livraison...") */
          #snipcart [class*="snipcart-typography--secondary"],
          #snipcart [class*="snipcart-typography--small"],
          #snipcart .snipcart__font--tiny,
          #snipcart .snipcart__font--secondary {
            color: #A3A3A3 !important;
            background-color: transparent !important;
          }

          /* Labels de formulaire (checkout) — plus lumineux pour la lisibilité */
          #snipcart label,
          #snipcart .snipcart-form__label,
          #snipcart [class*="snipcart-form__label"],
          #snipcart [class*="snipcart-input__label"] {
            color: #D4D4D8 !important;
            background-color: transparent !important;
            font-weight: 400 !important;
          }

          /* Bouton "Modifier" dans le résumé du checkout */
          #snipcart button[class*="modify"],
          #snipcart a[class*="modify"],
          #snipcart .snipcart-cart-summary-modify,
          #snipcart .snipcart-cart-summary__edit-btn {
            background-color: rgba(255,255,255,0.04) !important;
            color: #D4D4D8 !important;
            border: 1px solid rgba(255,255,255,0.12) !important;
            border-radius: 9999px !important;
            padding: 0.3rem 0.9rem !important;
          }
          #snipcart button[class*="modify"]:hover,
          #snipcart a[class*="modify"]:hover {
            background-color: rgba(255,255,255,0.08) !important;
            color: #F4F4F7 !important;
            border-color: rgba(255,255,255,0.25) !important;
          }

          /* Numéro d'étape (cercle "1", "2"...) */
          #snipcart .snipcart-layout__step-number,
          #snipcart [class*="step-number"],
          #snipcart [class*="step__number"] {
            background-color: rgba(255,255,255,0.05) !important;
            color: #F4F4F7 !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
          }

          /* Prix, line items, totaux — tous en blanc */
          #snipcart [class*="snipcart-price"],
          #snipcart [class*="snipcart-cart-summary-item"],
          #snipcart [class*="snipcart-cart-summary-fees"],
          #snipcart [class*="snipcart-item-line__label"],
          #snipcart [class*="snipcart-item-line__content"],
          #snipcart [class*="snipcart-item-quantity"],
          #snipcart .snipcart-item-list__item {
            color: #F4F4F7 !important;
            background-color: transparent !important;
          }

          /* Boutons primaires — pilule blanche, texte noir */
          #snipcart .snipcart-cart-button--highlight,
          #snipcart .snipcart-button-primary,
          #snipcart button[class*="snipcart-button-primary"],
          #snipcart button[type="submit"] {
            background-color: #F4F4F7 !important;
            color: #0A0A0A !important;
            border-radius: 9999px !important;
            border: none !important;
            padding: 0.9rem 1.5rem !important;
          }
          /* Enfants du bouton primaire : transparent + texte noir
             (sinon mon wildcard précédent leur mettait un bg noir visible) */
          #snipcart .snipcart-cart-button--highlight *,
          #snipcart .snipcart-button-primary *,
          #snipcart button[class*="snipcart-button-primary"] *,
          #snipcart button[type="submit"] *,
          #snipcart .snipcart-cart-button--highlight [class^="snipcart-"],
          #snipcart .snipcart-button-primary [class^="snipcart-"],
          #snipcart button[type="submit"] [class^="snipcart-"] {
            background-color: transparent !important;
            color: #0A0A0A !important;
            fill: #0A0A0A !important;
            stroke: #0A0A0A !important;
          }
          #snipcart .snipcart-cart-button--highlight:hover,
          #snipcart .snipcart-button-primary:hover,
          #snipcart button[type="submit"]:hover {
            background-color: #E5E5E5 !important;
          }

          /* Boutons secondaires / links / "Continuer les achats" */
          #snipcart .snipcart-button-secondary,
          #snipcart .snipcart-button-link,
          #snipcart a[class*="snipcart-button-link"],
          #snipcart button[class*="snipcart-button-link"],
          #snipcart [class*="snipcart__actions--link"],
          #snipcart .snipcart-continue-shopping,
          #snipcart a[class*="snipcart-continue"] {
            background-color: transparent !important;
            color: #A3A3A3 !important;
            border: 1px solid rgba(255,255,255,0.12) !important;
            border-radius: 9999px !important;
          }
          #snipcart .snipcart-button-secondary:hover,
          #snipcart .snipcart-button-link:hover,
          #snipcart [class*="snipcart__actions--link"]:hover {
            background-color: rgba(255,255,255,0.05) !important;
            color: #F4F4F7 !important;
          }

          /* Badges / pills (compteur panier, remove item, etc.) */
          #snipcart [class*="snipcart__badge"],
          #snipcart .snipcart-cart-item__remove-container button,
          #snipcart .snipcart-cart-item__remove {
            background-color: rgba(255,255,255,0.08) !important;
            color: #F4F4F7 !important;
            border-radius: 9999px !important;
          }

          /* ───────────────────────────────────────────────────────────
             Champs de formulaire — style GLIDE (pur neutre, subtil)
             Wrapper transparent + input avec bg neutre et bordure fine.
             ─────────────────────────────────────────────────────────── */
          /* Wrapper : transparent pour éviter le "box-in-box" */
          /* Structure Snipcart v3.7 :
               .snipcart-form__field           ← wrapper (label + box)
                 .snipcart-form__label         ← "Nom complet"
                 .snipcart-input               ← BOX VISIBLE (border, bg)
                   .snipcart-input__input      ← <input> réel (padding only)
             Le box visible = .snipcart-input. C'est LUI qu'on arrondit. */

          /* Les CSS vars Snipcart gèrent déjà bg/border/color pour
             .snipcart-input et ses états hover/focus/autofill.
             On ne touche qu'au border-radius (non exposé en var). */
          #snipcart .snipcart-input {
            border-radius: 0.5rem !important;
          }
          #snipcart .snipcart-input:focus-within {
            box-shadow: 0 0 0 2px rgba(255,255,255,0.06) !important;
          }

          /* Wrapper de champ : transparent (pas de "box-in-box") */
          #snipcart .snipcart-form__field,
          #snipcart .snipcart-form__select-wrapper {
            background-color: transparent !important;
            border: none !important;
          }

          /* Autofill — safety net au cas où --bgColor-input-autofill
             ne couvre pas tous les navigateurs. */
          #snipcart input:-webkit-autofill,
          #snipcart .snipcart-input__input:-webkit-autofill,
          #snipcart textarea:-webkit-autofill,
          #snipcart select:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 1000px #141414 inset !important;
            -webkit-text-fill-color: #F4F4F7 !important;
            caret-color: #F4F4F7 !important;
            transition: background-color 99999s ease-in-out 0s !important;
          }

          /* Quantité buttons (— 1 +) — même gris neutre */
          #snipcart .snipcart-item-quantity__quantity,
          #snipcart .snipcart-item-quantity__button {
            background-color: #141414 !important;
            color: #F4F4F7 !important;
            border: 1px solid rgba(255,255,255,0.08) !important;
          }

          /* Checkbox (ex. "Utiliser une adresse de livraison différente") */
          #snipcart [class*="snipcart-form__checkbox"],
          #snipcart [class*="checkbox__box"] {
            background-color: transparent !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            border-radius: 0.25rem !important;
          }
          #snipcart input[type="checkbox"]:checked + [class*="checkbox__box"],
          #snipcart [class*="checkbox__box"][class*="--checked"] {
            background-color: #F4F4F7 !important;
            border-color: #F4F4F7 !important;
          }

          /* ───────────────────────────────────────────────────────────
             Autocomplete d'adresse (Snipcart + Google Places)
             Sans ces règles, les suggestions sont transparentes et
             se superposent aux champs "Ville", "Pays", etc.
             ─────────────────────────────────────────────────────────── */
          #snipcart .snipcart-address-autocomplete__items,
          #snipcart .snipcart-autocomplete__items,
          #snipcart [class*="autocomplete__items"],
          #snipcart [class*="autocomplete__dropdown"],
          #snipcart [class*="suggestions"] {
            background-color: #14141C !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            border-radius: 0.75rem !important;
            box-shadow: 0 12px 40px rgba(0,0,0,0.6) !important;
            z-index: 10050 !important;
            overflow: hidden !important;
          }
          #snipcart .snipcart-address-autocomplete__item,
          #snipcart .snipcart-autocomplete__item,
          #snipcart [class*="autocomplete__item"] {
            background-color: transparent !important;
            color: #F4F4F7 !important;
            padding: 0.75rem 1rem !important;
            border: none !important;
            border-bottom: 1px solid rgba(255,255,255,0.06) !important;
          }
          #snipcart .snipcart-address-autocomplete__item:last-child,
          #snipcart [class*="autocomplete__item"]:last-child {
            border-bottom: none !important;
          }
          #snipcart .snipcart-address-autocomplete__item:hover,
          #snipcart [class*="autocomplete__item"]:hover,
          #snipcart [class*="autocomplete__item--highlighted"],
          #snipcart [class*="autocomplete__item--active"] {
            background-color: rgba(255,255,255,0.05) !important;
            color: #FFFFFF !important;
          }

          /* Google Places autocomplete (injecté dans <body>, hors de #snipcart) */
          .pac-container {
            background-color: #14141C !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            border-radius: 0.75rem !important;
            box-shadow: 0 12px 40px rgba(0,0,0,0.6) !important;
            margin-top: 4px !important;
            font-family: 'Inter', system-ui, sans-serif !important;
            overflow: hidden !important;
            z-index: 100000 !important;
          }
          .pac-item {
            background-color: transparent !important;
            color: #F4F4F7 !important;
            padding: 0.75rem 1rem !important;
            border-top: 1px solid rgba(255,255,255,0.06) !important;
            cursor: pointer !important;
          }
          .pac-item:first-child { border-top: none !important; }
          .pac-item:hover,
          .pac-item-selected,
          .pac-item.pac-item-selected {
            background-color: rgba(255,255,255,0.05) !important;
          }
          .pac-item-query,
          .pac-matched {
            color: #FFFFFF !important;
            font-weight: 500 !important;
          }
          .pac-item span:not(.pac-item-query) {
            color: #A3A3A3 !important;
          }
          .pac-icon {
            filter: invert(1) opacity(0.7) !important;
          }

          /* Dividers / séparateurs / hr */
          #snipcart hr,
          #snipcart .snipcart__separator,
          #snipcart [class*="separator"] {
            border-color: rgba(255,255,255,0.08) !important;
            background-color: rgba(255,255,255,0.08) !important;
          }

          /* Empty cart illustration — si SVG noir, on l'inverse ; si image, on la laisse */
          #snipcart .snipcart-cart__empty svg,
          #snipcart .snipcart-cart__empty-icon svg {
            filter: invert(1) contrast(0.85) !important;
          }

          /* Snipcart modal sits below the fixed site header so nothing overlaps.
             Apply the offset ONLY on the outermost fixed overlay. */
          #snipcart .snipcart-modal {
            top: var(--header-h) !important;
            height: calc(100vh - var(--header-h)) !important;
            max-height: calc(100vh - var(--header-h)) !important;
          }
        `} />
        <script is:inline define:vars={{ publicKey: siteConfig.shop.publicKey, currency: siteConfig.shop.currency }}>
          window.SnipcartSettings = {
            publicApiKey: publicKey,
            currency: currency,
            version: '3.7.1',
            loadStrategy: 'on-user-interaction',
