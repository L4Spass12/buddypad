---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';
import { parseEntrySlug } from '../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Cette route catch-all à la racine émet uniquement les articles FR
  // (sinon les fichiers en/foo.md seraient publiés en /en/foo/ AVANT que
  // les routes EN/DE et le i18n config soient activés en phase 7).
  return posts
    .filter(p => parseEntrySlug(p.slug).lang === 'fr')
    .map(post => ({
      params: { slug: post.slug },
      props: { post, allPosts: posts },
    }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();
const postLang = parseEntrySlug(post.slug).lang;

// Related : même catégorie ET même langue — évite qu'un article EN tombe dans
// les "À lire aussi" d'un article FR (et vice-versa).
const related = allPosts
  .filter(p => p.slug !== post.slug
    && p.data.category === post.data.category
    && parseEntrySlug(p.slug).lang === postLang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BlogLayout post={post} headings={headings} related={related}>
  <Content />
</BlogLayout>
