---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import siteConfig from '../../../site.config.mjs';
import { unsplashSrcset, unsplashAt } from '../../lib/image';

export function catToSlug(cat: string) {
  return cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
}

const CATEGORIES = siteConfig.categories as unknown as string[];

export async function getStaticPaths() {
  const CATS = siteConfig.categories as unknown as string[];
  const all = await getCollection('blog');
  return CATS.map(cat => ({
    params: { category: catToSlug(cat) },
    props: {
      cat,
      posts: all
        .filter(p => p.data.category === cat)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { cat, posts } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);

const SITE_URL = siteConfig.url;
const catSlug = catToSlug(cat);
---

<BaseLayout
  title={`${cat} — Blog ${siteConfig.name}`}
  description={`Tous les articles ${siteConfig.name} dans la catégorie ${cat} : conseils, inspirations et guides pratiques.`}
>
  <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-n-500 mb-10 font-light">
      <a href="/" class="hover:text-cream transition-colors">Accueil</a>
      <span>/</span>
      <a href="/blog" class="hover:text-cream transition-colors">Blog</a>
      <span>/</span>
      <span class="text-n-400">{cat}</span>
    </nav>

    <div class="mb-12">
      <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-3 block">{posts.length} article{posts.length > 1 ? 's' : ''}</span>
      <h1 class="text-4xl md:text-5xl font-medium tracking-tight text-cream leading-[1.1] mb-3">{cat}</h1>
      <p class="text-sm text-n-400 font-light">Tous nos articles dans la catégorie {cat}.</p>
    </div>

    <!-- Filtres catégories -->
    <div class="flex flex-wrap gap-2 mb-12">
      <a href="/blog" class="text-xs font-medium px-4 py-2 rounded-full border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20 transition-colors">
        Tous
      </a>
      {CATEGORIES.map(c => (
        <a
          href={`/category/${catToSlug(c)}`}
          class={`text-xs font-medium px-4 py-2 rounded-full transition-colors ${c === cat ? 'bg-cream text-dark' : 'border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20'}`}
        >
          {c}
        </a>
      ))}
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {posts.map(post => (
          <a href={`/${post.slug}`} class="group block">
            <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-panel border border-white/[0.05] mb-5">
              {post.data.image
                ? <img
                    src={unsplashAt(post.data.image, 600)}
                    srcset={unsplashSrcset(post.data.image, [400, 600, 800])}
                    sizes="(max-width: 768px) calc(100vw - 32px), (max-width: 1024px) calc(50vw - 48px), 380px"
                    alt={post.data.imageAlt ?? post.data.title}
                    class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                    width="800" height="600" loading="lazy"
                  />
                : <div class="w-full h-full flex items-center justify-center text-n-500"><Icon name="mouse" size={48} strokeWidth={1.25} /></div>
              }
            </div>
            <div>
              <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-2 block">{post.data.category}</span>
              <h2 class="text-base font-medium text-cream tracking-tight leading-snug group-hover:underline underline-offset-4">
                {post.data.title}
              </h2>
              <p class="text-xs text-n-500 font-light line-clamp-2 mt-1">{post.data.description}</p>
              <time datetime={post.data.pubDate.toISOString()} class="text-[11px] text-n-500 font-light mt-3 block">{formatDate(post.data.pubDate)}</time>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-sm text-n-500 font-light">Aucun article dans cette catégorie pour l'instant.</p>
      </div>
    )}
  </div>
</BaseLayout>
