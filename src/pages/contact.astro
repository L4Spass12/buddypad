---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../../site.config.mjs';

const title = "Contact";
const description = "Une question sur nos tapis de souris, une commande ou la livraison ? Notre équipe vous répond généralement sous 24 heures.";
const web3formsKey = siteConfig.forms?.web3formsKey ?? '';
---

<BaseLayout title={`${title} | ${siteConfig.name}`} description={description}>
  <div class="max-w-3xl mx-auto px-6 py-16 md:py-20">
    <!-- En-tête -->
    <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-3 block">Nous contacter</span>
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-cream leading-[1.1] mb-5">
      {title}
    </h1>
    <p class="text-base text-n-400 leading-relaxed mb-12 font-light max-w-xl">
      Une question sur nos tapis de souris, une commande en cours ou un problème de livraison ?
      Remplissez le formulaire ci-dessous, notre équipe vous répond généralement sous <strong class="text-cream font-medium">24 heures ouvrées</strong>.
    </p>

    <!-- Formulaire -->
    <form id="contact-form" class="space-y-5" novalidate>
      <!-- Champs cachés Web3Forms -->
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="Nouveau message contact - BuddyPad" />
      <input type="hidden" name="from_name" value="Formulaire BuddyPad" />
      <!-- Honeypot anti-bot (laissez vide) -->
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <!-- Prénom + Nom : 2 colonnes desktop, 1 colonne mobile -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label for="contact-firstname" class="block text-xs text-n-400 font-medium mb-2">Prénom <span class="text-cream">*</span></label>
          <input
            type="text"
            id="contact-firstname"
            name="prenom"
            required
            autocomplete="given-name"
            class="w-full bg-panel border border-white/[0.08] rounded-lg px-4 py-3 text-sm text-cream placeholder-n-500 focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/20 transition-colors"
          />
        </div>
        <div>
          <label for="contact-lastname" class="block text-xs text-n-400 font-medium mb-2">Nom <span class="text-cream">*</span></label>
          <input
            type="text"
            id="contact-lastname"
            name="nom"
            required
            autocomplete="family-name"
            class="w-full bg-panel border border-white/[0.08] rounded-lg px-4 py-3 text-sm text-cream placeholder-n-500 focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/20 transition-colors"
          />
        </div>
      </div>

      <!-- Email -->
      <div>
        <label for="contact-email" class="block text-xs text-n-400 font-medium mb-2">Email <span class="text-cream">*</span></label>
        <input
          type="email"
          id="contact-email"
          name="email"
          required
          autocomplete="email"
          placeholder="vous@exemple.com"
          class="w-full bg-panel border border-white/[0.08] rounded-lg px-4 py-3 text-sm text-cream placeholder-n-500 focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/20 transition-colors"
        />
      </div>

      <!-- Sujet (optionnel, predefined) -->
      <div>
        <label for="contact-topic" class="block text-xs text-n-400 font-medium mb-2">Objet</label>
        <select
          id="contact-topic"
          name="objet"
          class="w-full bg-panel border border-white/[0.08] rounded-lg px-4 py-3 text-sm text-cream focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/20 transition-colors appearance-none"
        >
          <option value="">- Sélectionnez -</option>
          <option value="Question avant achat">Question avant achat</option>
          <option value="Suivi de commande">Suivi de commande</option>
          <option value="Problème de livraison">Problème de livraison</option>
          <option value="Retour ou remboursement">Retour ou remboursement</option>
          <option value="Tapis personnalisé">Tapis personnalisé</option>
          <option value="Partenariat / collaboration">Partenariat / collaboration</option>
          <option value="Autre">Autre</option>
        </select>
      </div>

      <!-- Message -->
      <div>
        <label for="contact-message" class="block text-xs text-n-400 font-medium mb-2">Message <span class="text-cream">*</span></label>
        <textarea
          id="contact-message"
          name="message"
          rows="6"
          required
          placeholder="Décrivez votre demande en quelques lignes…"
          class="w-full bg-panel border border-white/[0.08] rounded-lg px-4 py-3 text-sm text-cream placeholder-n-500 focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/20 transition-colors resize-y min-h-[140px]"
        ></textarea>
      </div>

      <!-- Submit + état -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-2">
        <button
          type="submit"
          id="contact-submit"
          class="btn-primary inline-flex items-center justify-center gap-2 px-8 py-3 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span data-submit-label>Envoyer le message</span>
          <svg data-submit-spinner class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <circle cx="12" cy="12" r="9" stroke-opacity="0.25"/>
            <path d="M21 12a9 9 0 0 1-9 9" />
          </svg>
        </button>
        <p class="text-xs text-n-500 font-light">
          Réponse sous 24h ouvrées · Vos données sont confidentielles.
        </p>
      </div>

      <!-- Messages de retour -->
      <div
        id="contact-success"
        class="hidden rounded-xl border border-sage/30 bg-sage/[0.08] px-5 py-4 text-sm text-sage"
        role="status"
      >
        ✓ Message envoyé ! Notre équipe vous répond sous 24 heures.
      </div>
      <div
        id="contact-error"
        class="hidden rounded-xl border border-terracotta/30 bg-terracotta/[0.08] px-5 py-4 text-sm text-terracotta"
        role="alert"
      >
        Une erreur est survenue. Merci de réessayer ou de nous écrire directement à
        <a href="mailto:contact@buddypad.com" class="underline">contact@buddypad.com</a>.
      </div>
    </form>

    <!-- Contact direct alternatif -->
    <div class="mt-12 pt-8 border-t border-white/[0.08]">
      <p class="text-xs text-n-500 font-light">
        Vous pouvez aussi nous écrire directement à
        <a href="mailto:contact@buddypad.com" class="text-cream hover:underline underline-offset-4">contact@buddypad.com</a>.
      </p>
    </div>
  </div>

  <!-- Soumission via Web3Forms (POST fetch, pas de page reload) -->
  <script is:inline>
    (function() {
      const form = document.getElementById('contact-form');
      if (!form) return;
      const submit = document.getElementById('contact-submit');
      const label  = form.querySelector('[data-submit-label]');
      const spin   = form.querySelector('[data-submit-spinner]');
      const okBox  = document.getElementById('contact-success');
      const errBox = document.getElementById('contact-error');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        okBox.classList.add('hidden');
        errBox.classList.add('hidden');
        submit.disabled = true;
        label.textContent = 'Envoi en cours…';
        spin.classList.remove('hidden');

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Accept': 'application/json' },
            body: new FormData(form),
          });
          const data = await res.json();
          if (res.ok && data.success) {
            okBox.classList.remove('hidden');
            form.reset();
          } else {
            console.error('Web3Forms error', data);
            errBox.classList.remove('hidden');
          }
        } catch (err) {
          console.error('Submit error', err);
          errBox.classList.remove('hidden');
        } finally {
          submit.disabled = false;
          label.textContent = 'Envoyer le message';
          spin.classList.add('hidden');
        }
      });
    })();
  </script>
</BaseLayout>
