		</div>
		<div id="wpforms-3072-field_1-container" class="wpforms-field wpforms-field-name" data-field-id="1"><fieldset><legend class="wpforms-field-label">Nom <span class="wpforms-required-label" aria-hidden="true">*</span></legend><div class="wpforms-field-row wpforms-field-medium"><div class="wpforms-field-row-block wpforms-first wpforms-one-half"><input type="text" id="wpforms-3072-field_1" class="wpforms-field-name-first wpforms-field-required" name="wpforms[fields][1][first]" aria-errormessage="wpforms-3072-field_1-error" required><label for="wpforms-3072-field_1" class="wpforms-field-sublabel after">Prénom</label></div><div class="wpforms-field-row-block wpforms-one-half"><input type="text" id="wpforms-3072-field_1-last" class="wpforms-field-name-last wpforms-field-required" name="wpforms[fields][1][last]" aria-errormessage="wpforms-3072-field_1-last-error" required><label for="wpforms-3072-field_1-last" class="wpforms-field-sublabel after">Nom</label></div></div></fieldset></div><div id="wpforms-3072-field_2-container" class="wpforms-field wpforms-field-email" data-field-id="2"><label class="wpforms-field-label" for="wpforms-3072-field_2">E-mail <span class="wpforms-required-label" aria-hidden="true">*</span></label><input type="email" id="wpforms-3072-field_2" class="wpforms-field-medium wpforms-field-required" name="wpforms[fields][2]" spellcheck="false" aria-errormessage="wpforms-3072-field_2-error" required></div><div id="wpforms-3072-field_3-container" class="wpforms-field wpforms-field-textarea" data-field-id="3"><label class="wpforms-field-label" for="wpforms-3072-field_3">Commentaire ou message</label><textarea id="wpforms-3072-field_3" class="wpforms-field-medium" name="wpforms[fields][3]" aria-errormessage="wpforms-3072-field_3-error" ></textarea></div><script>
				( function() {
					const style = document.createElement( 'style' );
					style.appendChild( document.createTextNode( '#wpforms-3072-field_4-container { position: absolute !important; overflow: hidden !important; display: inline !important; height: 1px !important; width: 1px !important; z-index: -1000 !important; padding: 0 !important; } #wpforms-3072-field_4-container input { visibility: hidden; } #wpforms-conversational-form-page #wpforms-3072-field_4-container label { counter-increment: none; }' ) );
					document.head.appendChild( style );
					document.currentScript?.remove();
				} )();
			</script></div><!-- .wpforms-field-container --><div class="wpforms-submit-container" ><input type="hidden" name="wpforms[id]" value="3072"><input type="hidden" name="page_title" value=""><input type="hidden" name="page_url" value="https://buddypad.com/wp-json/wp/v2/pages?per_page=100&#038;page=1"><input type="hidden" name="url_referer" value=""><button type="submit" name="wpforms[submit]" id="wpforms-submit-3072" class="wpforms-submit" data-alt-text="Envoi..." data-submit-text="Envoyer" aria-live="assertive" value="wpforms-submit">Envoyer</button><img decoding="async" src="https://buddypad.com/wp-content/plugins/wpforms-lite/assets/images/submit-spin.svg" class="wpforms-submit-spinner" style="display: none;" width="26" height="26" alt="Chargement en cours"></div></form></div>  <!-- .wpforms-container --></div>
