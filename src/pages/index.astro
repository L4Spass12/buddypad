---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Icon from '../components/Icon.astro';
import siteConfig from '../../site.config.mjs';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function catToSlug(cat) {
  return siteConfig.categorySlugs?.[cat]
    ?? cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

const categoryDescriptions = {
  'Tapis de souris Gaming': 'Tests, comparatifs et guides d\'achat pour gamers exigeants.',
  "Guide d’achat & conseils": 'Choisir, nettoyer, entretenir : tout ce qu\'il faut savoir avant d\'acheter.',
  'Bureau & Setup': 'Aménagement, télétravail, desk mats : inspirer un bureau qui a du sens.',
};

const categoryIcons = {
  'Tapis de souris Gaming': 'gamepad',
  "Guide d’achat & conseils": 'star',
  'Bureau & Setup': 'desk',
};

const faqs = [
  {
    q: 'Tapis de souris gaming ou bureautique, lequel choisir ?',
    a: `Cela dépend de votre usage principal. Un tapis gaming privilégie la vitesse du glisse, la précision et la taille (souvent XXL pour couvrir aussi le clavier). Un tapis bureautique mise sur la stabilité, la durabilité et un toucher agréable. Si vous alternez, un tapis hybride type "contrôle" est un bon compromis.`,
  },
  {
    q: 'Un grand tapis XXL vaut-il vraiment le coup ?',
    a: `Oui, surtout en gaming compétitif et pour les sensibilités de souris basses. Un tapis XXL (90×40 cm ou plus) couvre la souris ET le clavier, uniformise la surface, et évite que la souris ne sorte du tapis en plein combat. Il protège aussi le bureau des rayures.`,
  },
  {
    q: 'Les tapis RGB améliorent-ils les performances ?',
    a: `Non, techniquement le RGB n'améliore pas la précision ni la vitesse. Mais c'est un vrai plus esthétique pour un setup gaming, et certains modèles intègrent un hub USB ou une recharge sans fil pour la souris — là, ça devient pratique.`,
  },
  {
    q: 'Comment nettoyer un tapis de souris ?',
    a: `À la main avec de l'eau tiède et un peu de savon doux, en frottant délicatement avec une éponge. Rincez abondamment et laissez sécher à plat, à l'air libre (jamais au sèche-cheveux ni au soleil direct). Évitez la machine à laver sur les modèles avec base caoutchouc cousue.`,
  },
  {
    q: 'Quelle surface choisir : tissu, dur ou hybride ?',
    a: `Le tissu est polyvalent, confortable et discret — parfait pour 90 % des usages. Les surfaces dures (plastique, aluminium) sont ultra-rapides mais bruyantes et usent plus vite les patins de souris. Les hybrides offrent un entre-deux pour ceux qui veulent vitesse ET contrôle.`,
  },
];

const SITE_URL = siteConfig.url;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  description: siteConfig.description,
  url: SITE_URL,
  inLanguage: 'fr-FR',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={`${siteConfig.name} – Tapis de souris gaming & bureautique`}
  description={siteConfig.description}
  jsonLd={[websiteSchema, faqSchema]}
>
    <!-- Hero -->
    <section class="relative pt-24 pb-16 md:pt-40 md:pb-28 px-6 overflow-hidden">
      <!-- Decorative background gradient -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-white/[0.03] blur-[120px] rounded-[100%] pointer-events-none"></div>

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <span class="tag tag-status mb-8">Nouveau : sélection 2026</span>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-medium tracking-tight text-cream mb-6 leading-[1.1]">
          La surface parfaite pour<br class="hidden md:block" />
          une précision absolue.
        </h1>

        <p class="text-base md:text-lg text-n-400 mb-10 max-w-2xl mx-auto font-light">
          Des tapis de souris testés, analysés et sélectionnés pour offrir une friction minimale, une base antidérapante inébranlable et une esthétique qui sublime votre setup.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/blog" class="w-full sm:w-auto btn-primary">Explorer le blog</a>
          <a href="#categories" class="w-full sm:w-auto btn-outline">Découvrir les catégories</a>
        </div>
      </div>
    </section>

    <!-- À propos -->
    <section id="a-propos" class="py-24 px-6 border-y border-white/[0.04] bg-panel">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-cream mb-4">
            Le média pour équiper son bureau.
          </h2>
          <p class="text-sm text-n-500 max-w-xl mx-auto font-light">
            Tests, analyses et conseils — sans filler marketing.
          </p>
        </div>
        <div class="prose prose-invert prose-lg max-w-none prose-p:font-light prose-p:text-n-400 prose-p:leading-relaxed prose-strong:text-cream prose-strong:font-medium">
          <p>
            <strong>{siteConfig.name}</strong> est le site francophone dédié aux <strong>tapis de souris gaming et bureautique</strong>, ainsi qu'à l'optimisation complète de votre poste de travail. Notre mission : vous aider à trouver le matériel qui <strong>change vraiment votre expérience</strong>, sans vous ruiner en RGB inutile.
          </p>
          <p>
            Chaque semaine, nous publions des <strong>tests approfondis</strong>, des <strong>guides d'achat</strong> et des <strong>comparatifs</strong>. Du joueur compétitif à l'utilisateur bureautique intensif, vous trouverez des conseils adaptés à votre usage réel.
          </p>
          <p>
            Un bon tapis ne se voit pas : il se <strong>sent sous la souris</strong>, il préserve vos poignets, et il tient des années.
          </p>
        </div>
      </div>
    </section>

    <!-- Catégories -->
    <section id="categories" class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-cream mb-4">
            L'ingénierie au service du mouvement.
          </h2>
          <p class="text-sm text-n-500 max-w-xl mx-auto font-light">
            Cinq univers, chacun optimisé pour un usage précis.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          {siteConfig.categories.map(cat => (
            <a
              href={`/category/${catToSlug(cat)}`}
              class="group flex flex-col items-center text-center"
            >
              <div class="h-12 w-12 rounded-full border border-white/[0.08] bg-white/[0.02] flex items-center justify-center mb-6 text-cream group-hover:border-white/30 transition-colors">
                <Icon name={categoryIcons[cat] ?? 'sparkle'} size={22} strokeWidth={1.5} />
              </div>
              <h3 class="text-lg font-medium text-cream tracking-tight mb-2 group-hover:underline underline-offset-4">
                {cat}
              </h3>
              <p class="text-sm text-n-500 font-light leading-relaxed max-w-xs">
                {categoryDescriptions[cat] ?? `Articles et conseils autour de ${cat.toLowerCase()}.`}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog preview -->
    {recentPosts.length > 0 && <BlogPreview posts={recentPosts} />}

    <!-- FAQ -->
    <section class="py-24 px-6 border-t border-white/[0.04] bg-panel">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-cream mb-4">
            Questions fréquentes
          </h2>
        </div>
        <div class="space-y-3">
          {faqs.map(f => (
            <details class="group rounded-2xl border border-white/[0.08] bg-dark open:border-white/20 transition-colors">
              <summary class="flex items-start justify-between gap-4 px-6 py-5 cursor-pointer list-none font-medium text-base text-cream tracking-tight">
                <span class="flex-1">{f.q}</span>
                <span class="text-n-400 text-xl leading-none transition-transform group-open:rotate-45 shrink-0">+</span>
              </summary>
              <p class="px-6 pb-5 pt-1 font-light text-sm text-n-400 leading-relaxed">
                {f.a}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="relative py-24 px-6 overflow-hidden">
      <div class="absolute -bottom-40 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-white/[0.04] blur-[120px] rounded-[100%] pointer-events-none"></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-cream mb-4 leading-[1.1]">
          Prêt à upgrader votre setup ?
        </h2>
        <p class="text-base text-n-400 mb-10 max-w-xl mx-auto font-light">
          Explorez la boutique et le blog pour trouver la surface qui correspond à votre style.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          {siteConfig.shop?.enabled && <a href="/tapis-de-souris" class="w-full sm:w-auto btn-primary">Voir la boutique</a>}
          <a href="/blog" class="w-full sm:w-auto btn-outline">Lire le blog</a>
        </div>
      </div>
    </section>
</BaseLayout>
