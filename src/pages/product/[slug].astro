---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import FabricationSection from '../../components/FabricationSection.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../../../site.config.mjs';
import { unsplashSrcset } from '../../lib/image';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await product.render();
const {
  name, price, compareAtPrice, priceRange, image, imageAlt, gallery,
  categories, shortDescription, stock, sku, attributes, variations,
} = product.data;

const allProducts = await getCollection('products');

// ─── Sélection catégorie pour "Vous aimerez aussi" ─────────────────────
// Les catégories transversales (taille, feature) contiennent TOUS les produits
// → on préfère une catégorie thématique. Priorité bas = déprioritisé.
const GENERIC_CATEGORIES = new Set([
  'tapis-de-souris-xxl',                          // taille
  'tapis-souris-led-rgb',                         // feature
  'tapis-souris-led-rgb-charge-sans-fil',         // feature
]);
const preferredCategory = (categories || []).find(c => !GENERIC_CATEGORIES.has(c))
  ?? categories?.[0];

// TOUS les produits de cette collection thématique (hors produit courant)
const related = allProducts
  .filter(p => p.slug !== product.slug && (p.data.categories || []).includes(preferredCategory));

const formatPrice = (n: number) => new Intl.NumberFormat('fr-FR', {
  style: 'currency', currency: siteConfig.shop.currency,
}).format(n);

const SITE_URL = siteConfig.url;
const productUrl = `${SITE_URL}/product/${product.slug}/`;
const imageUrl = new URL(image, SITE_URL).toString();
const hasVariations = Array.isArray(variations) && variations.length > 0;
const inStock = hasVariations ? variations.some(v => v.inStock) : (stock == null || stock > 0);

// ─── SEO : titre court + meta description unique par produit ──────────
// Titre : max ~60 chars. "Nom du produit | BuddyPad" si ça rentre,
// sinon juste "Nom du produit" (sans le nom du site).
const brandSuffix = ` | ${siteConfig.name}`;
const seoTitle = (name.length + brandSuffix.length) <= 60
  ? `${name}${brandSuffix}`
  : name;

// Meta description : combine shortDesc tronquée + catégorie + prix pour garantir
// l'unicité même si shortDescription est dupliquée entre produits.
// Format : "<nom>. <shortDesc courte>. À partir de X€. Livraison dès 49€."
const priceStart = priceRange?.min ?? price;
const catLabel = categories?.[0]?.replace(/^tapis-de-souris-/, '').replace(/-/g, ' ') ?? '';
const truncated = shortDescription.length > 70
  ? shortDescription.slice(0, 70).replace(/\s+\S*$/, '') + '…'
  : shortDescription;
const rawDesc = `${name}${catLabel ? ` ${catLabel}` : ''}. ${truncated} Dès ${priceStart}€, livraison offerte dès 49€.`;
const seoDescription = rawDesc.length > 160
  ? rawDesc.slice(0, 160).replace(/\s+\S*$/, '') + '…'
  : rawDesc;

// Serialize variations + attributes pour le JS client (sélecteur de variantes)
const variantsJson = JSON.stringify(variations || []);

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  description: shortDescription,
  image: [imageUrl, ...(gallery || []).slice(1).map(g => new URL(g, SITE_URL).toString())],
  sku: sku ?? product.slug,
  brand: { '@type': 'Brand', name: siteConfig.name },
  offers: hasVariations ? {
    '@type': 'AggregateOffer',
    priceCurrency: siteConfig.shop.currency,
    lowPrice: priceRange?.min ?? price,
    highPrice: priceRange?.max ?? price,
    offerCount: variations.length,
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  } : {
    '@type': 'Offer',
    url: productUrl,
    priceCurrency: siteConfig.shop.currency,
    price: price.toFixed(2),
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    itemCondition: 'https://schema.org/NewCondition',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Boutique', item: `${SITE_URL}/tapis-de-souris` },
    { '@type': 'ListItem', position: 3, name, item: productUrl },
  ],
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={image}
  jsonLd={[productSchema, breadcrumbSchema]}
>
  <div class="max-w-7xl mx-auto px-6 pt-6 md:pt-8 pb-16 md:pb-20">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-n-500 mb-10 overflow-x-auto whitespace-nowrap pb-1 font-light">
      <a href="/" class="hover:text-cream transition-colors shrink-0">Accueil</a>
      <span class="shrink-0">/</span>
      <a href="/tapis-de-souris" class="hover:text-cream transition-colors shrink-0">Boutique</a>
      <span class="shrink-0">/</span>
      <span class="text-n-400 truncate">{name}</span>
    </nav>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
      <!-- ═══════════════════════════ GALERIE ═══════════════════════════ -->
      {(() => {
        // Galerie épurée : UNIQUEMENT image principale + gallery définie dans le frontmatter.
        // Les images de variations ne sont PAS ajoutées (design épuré).
        // Au changement de variante, le slide principal sera swappé directement via JS.
        const slides = Array.from(new Set([image, ...(gallery || [])]));
        return (
        <div class="product-gallery" data-gallery data-slide-count={slides.length}>
          <!-- Viewport : scroll-snap horizontal. Sur mobile = swipe natif,
               sur desktop = flèches prev/next. Une seule image visible à la fois. -->
          <div class="relative rounded-2xl overflow-hidden bg-panel border border-white/[0.05] aspect-[4/3] group">
            <div
              class="gallery-track flex overflow-x-auto snap-x snap-mandatory scroll-smooth h-full"
              data-gallery-track
            >
              {slides.map((src, i) => (
                <div class="flex-none w-full h-full snap-start snap-always">
                  <img
                    data-gallery-slide={i}
                    src={src}
                    srcset={unsplashSrcset(src)}
                    sizes="(max-width: 1024px) 100vw, 560px"
                    alt={i === 0 ? (imageAlt ?? name) : `${name} — image ${i + 1}`}
                    class="w-full h-full object-cover"
                    width="1200"
                    height="900"
                    fetchpriority={i === 0 ? 'high' : 'auto'}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              ))}
            </div>

            <!-- Flèches desktop uniquement (apparaissent au hover) -->
            {slides.length > 1 && (
              <>
                <button
                  type="button"
                  data-gallery-prev
                  aria-label="Image précédente"
                  class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark/80 backdrop-blur border border-white/[0.15] items-center justify-center text-cream opacity-0 group-hover:opacity-100 hover:bg-dark hover:border-white/30 disabled:opacity-0 disabled:pointer-events-none transition-all z-10"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <button
                  type="button"
                  data-gallery-next
                  aria-label="Image suivante"
                  class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark/80 backdrop-blur border border-white/[0.15] items-center justify-center text-cream opacity-0 group-hover:opacity-100 hover:bg-dark hover:border-white/30 disabled:opacity-0 disabled:pointer-events-none transition-all z-10"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </>
            )}
          </div>

          <!-- Thumbs : DESKTOP uniquement. Sur mobile → swipe natif. -->
          {slides.length > 1 && (
            <div class="hidden md:grid grid-cols-5 gap-2 mt-3">
              {slides.slice(0, 10).map((g, i) => (
                <button
                  type="button"
                  data-gallery-thumb={i}
                  class={`gallery-thumb aspect-square rounded-lg overflow-hidden border transition-colors ${i === 0 ? 'border-cream' : 'border-white/[0.08]'} hover:border-white/30`}
                  aria-label={`Voir l'image ${i + 1}`}
                >
                  <img src={g} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
                </button>
              ))}
            </div>
          )}
        </div>
        );
      })()}

      <!-- Info + CTA -->
      <div class="flex flex-col">
        <!-- Categories -->
        {categories && categories.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {categories.map(c => (
              <a
                href={`/product-category/${c}`}
                class="text-[10px] text-n-500 font-medium uppercase tracking-widest hover:text-cream transition-colors"
              >
                {c.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        )}

        <h1 class="text-xl md:text-2xl lg:text-3xl font-medium tracking-tight text-cream leading-[1.2] mb-3">
          {name}
        </h1>
        <p class="text-sm md:text-base text-n-400 leading-relaxed mb-6 font-light">
          {shortDescription}
        </p>

        <!-- Prix -->
        <div class="flex items-baseline gap-3 mb-2">
          <span id="product-price" class="text-2xl md:text-3xl text-cream font-medium tracking-tight">
            {priceRange && priceRange.min !== priceRange.max
              ? `Dès ${formatPrice(priceRange.min)}`
              : formatPrice(price)}
          </span>
          {compareAtPrice && (
            <span id="product-compare" class="text-sm text-n-500 line-through font-light">
              {formatPrice(compareAtPrice)}
            </span>
          )}
          {compareAtPrice && (
            <span class="text-[10px] font-medium bg-cream text-dark px-2 py-1 rounded-sm uppercase tracking-wider">
              -{Math.round((1 - price / compareAtPrice) * 100)}%
            </span>
          )}
        </div>
        <p class="text-xs text-n-500 mb-8 font-light">TVA incluse — livraison calculée au checkout</p>

        <!-- Stock -->
        <div id="product-stock" class={`flex items-center gap-2 mb-6 text-sm font-light ${inStock ? 'text-sage' : 'text-n-500'}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${inStock ? 'bg-sage' : 'bg-n-500'}`}></span>
          <span>{inStock ? 'En stock' : 'Rupture de stock'}</span>
        </div>

        <!-- Sélecteurs de variantes -->
        {hasVariations && attributes.length > 0 && (
          <div id="variant-selector" class="space-y-6 mb-8">
            {attributes.map(attr => (
              <div>
                <label class="block text-xs text-n-500 uppercase tracking-widest mb-2 font-medium">
                  {attr.name} : <span class="text-cream" data-selected-label={attr.name}>—</span>
                </label>
                <div class="flex flex-wrap gap-2">
                  {attr.values.map((val, idx) => (
                    <button
                      type="button"
                      data-variant-option
                      data-attr={attr.name}
                      data-value={val.slug}
                      class={`variant-pill text-xs font-medium px-4 py-2 rounded-full border transition-colors ${idx === 0 ? 'bg-cream text-dark border-cream' : 'bg-white/[0.02] text-n-400 border-white/[0.08] hover:text-cream hover:border-white/20'}`}
                    >
                      {val.label}
                    </button>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}

        <!-- Bouton d'achat (Atelier) -->
        {siteConfig.shop?.provider === 'atelier' ? (
          <button
            id="buy-button"
            class="buy-button btn-primary text-sm px-8 py-4 disabled:opacity-40 disabled:cursor-not-allowed"
            disabled={!inStock}
            data-item-id={sku ?? product.slug}
            data-item-name={name}
            data-item-price={Math.round(price * 100)}
            data-item-image={image}
          >
            {inStock ? `Acheter — ${priceRange && priceRange.min !== priceRange.max ? `dès ${formatPrice(priceRange.min)}` : formatPrice(price)}` : 'Indisponible'}
          </button>
        ) : (
          <button
            class="snipcart-add-item btn-primary text-sm px-8 py-4 disabled:opacity-40 disabled:cursor-not-allowed"
            disabled={!inStock}
            data-item-id={sku ?? product.slug}
            data-item-name={name}
            data-item-price={price.toFixed(2)}
            data-item-url={`/product/${product.slug}/`}
            data-item-image={image}
          >
            {inStock ? 'Ajouter au panier' : 'Indisponible'}
          </button>
        )}

        <!-- Garanties -->
        <div class="grid grid-cols-2 gap-6 mt-10 pt-8 border-t border-white/[0.08]">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full border border-white/[0.08] bg-white/[0.02] flex items-center justify-center text-cream shrink-0">
              <Icon name="shield-check" size={16} strokeWidth={1.5} />
            </div>
            <div>
              <p class="text-xs font-medium text-cream tracking-tight">Livraison offerte</p>
              <p class="text-xs text-n-500 font-light">dès 49€ d'achat</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full border border-white/[0.08] bg-white/[0.02] flex items-center justify-center text-cream shrink-0">
              <Icon name="arrow-right" size={16} strokeWidth={1.5} />
            </div>
            <div>
              <p class="text-xs font-medium text-cream tracking-tight">Retour 30 jours</p>
              <p class="text-xs text-n-500 font-light">gratuit et simple</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════ TOGGLES PRODUIT ═══════════════════════════
         3 accordéons en HTML natif (<details>). Google indexe parfaitement le
         contenu à l'intérieur (ouvert ou fermé), donc SEO-friendly. Zéro JS. -->
    <section class="mt-16 max-w-3xl">
      <!-- Description -->
      <details class="product-toggle group border-t border-white/[0.08] py-5" open>
        <summary class="flex items-center justify-between gap-4 cursor-pointer list-none select-none">
          <h2 class="text-base md:text-lg font-medium text-cream tracking-tight">Description</h2>
          <svg class="w-5 h-5 text-n-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <article class="mt-5 prose prose-invert prose-base max-w-none
          prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-cream
          prose-h2:text-xl prose-h2:mt-10 prose-h3:text-lg
          prose-p:font-light prose-p:text-n-400 prose-p:leading-relaxed
          prose-a:text-cream prose-a:underline prose-a:underline-offset-4 prose-a:decoration-white/30 hover:prose-a:decoration-cream
          prose-strong:text-cream prose-strong:font-medium
          prose-ul:font-light prose-li:text-n-400
          prose-blockquote:border-cream prose-blockquote:bg-panel prose-blockquote:rounded-r-xl prose-blockquote:text-n-400
          prose-code:text-cream prose-code:bg-panel prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-normal">
          <Content />
        </article>
      </details>

      <!-- Livraison & retours -->
      <details class="product-toggle group border-t border-white/[0.08] py-5">
        <summary class="flex items-center justify-between gap-4 cursor-pointer list-none select-none">
          <h2 class="text-base md:text-lg font-medium text-cream tracking-tight">Livraison & retours</h2>
          <svg class="w-5 h-5 text-n-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="mt-5 space-y-4 text-sm text-n-400 font-light leading-relaxed">
          <div>
            <h3 class="text-cream font-medium mb-1.5">Expédition</h3>
            <p>Commande préparée sous 24 à 48 heures ouvrées. Expédition depuis notre atelier en France via Colissimo ou Mondial Relay selon votre choix au paiement.</p>
          </div>
          <div>
            <h3 class="text-cream font-medium mb-1.5">Délais de livraison</h3>
            <ul class="list-disc pl-5 space-y-1">
              <li>France métropolitaine : 2 à 4 jours ouvrés</li>
              <li>Europe (Belgique, Suisse, Luxembourg, Allemagne…) : 4 à 7 jours ouvrés</li>
              <li>Reste du monde : 7 à 14 jours ouvrés</li>
            </ul>
          </div>
          <div>
            <h3 class="text-cream font-medium mb-1.5">Frais de livraison</h3>
            <p><strong class="text-cream">Livraison offerte dès 49€ d'achat</strong> en France métropolitaine. En dessous, les frais sont calculés au checkout selon le transporteur sélectionné.</p>
          </div>
          <div>
            <h3 class="text-cream font-medium mb-1.5">Retours & remboursement</h3>
            <p>Vous disposez de <strong class="text-cream">30 jours après réception</strong> pour changer d'avis. Retour gratuit en France (étiquette prépayée fournie). Le produit doit être renvoyé dans son état d'origine, non utilisé et dans son emballage. Remboursement intégral sous 5 jours ouvrés après réception du colis.</p>
            <p class="mt-2 text-xs text-n-500">Les tapis personnalisés (impression sur-mesure d'un visuel client) ne sont ni repris ni échangés, sauf défaut de fabrication.</p>
          </div>
        </div>
      </details>

      <!-- Entretien -->
      <details class="product-toggle group border-t border-b border-white/[0.08] py-5">
        <summary class="flex items-center justify-between gap-4 cursor-pointer list-none select-none">
          <h2 class="text-base md:text-lg font-medium text-cream tracking-tight">Entretien</h2>
          <svg class="w-5 h-5 text-n-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="mt-5 space-y-4 text-sm text-n-400 font-light leading-relaxed">
          <div>
            <h3 class="text-cream font-medium mb-1.5">Nettoyage au quotidien</h3>
            <p>Pour les petites salissures, passez simplement un chiffon microfibre légèrement humidifié sur la surface. Laissez sécher à l'air libre avant réutilisation.</p>
          </div>
          <div>
            <h3 class="text-cream font-medium mb-1.5">Nettoyage en profondeur</h3>
            <ol class="list-decimal pl-5 space-y-1">
              <li>Remplissez une bassine d'eau tiède (30°C max) avec un peu de savon doux ou de shampoing neutre.</li>
              <li>Trempez le tapis, frottez délicatement la surface avec une éponge douce ou une brosse à poils souples.</li>
              <li>Rincez abondamment à l'eau claire jusqu'à disparition complète du savon.</li>
              <li>Essorez en pressant (jamais en tordant) puis laissez sécher <strong class="text-cream">à plat, à l'air libre</strong>, loin du soleil direct et de toute source de chaleur.</li>
            </ol>
          </div>
          <div>
            <h3 class="text-cream font-medium mb-1.5">À éviter absolument</h3>
            <ul class="list-disc pl-5 space-y-1">
              <li>Machine à laver (détériore la base caoutchouc cousue)</li>
              <li>Sèche-linge, sèche-cheveux, radiateur</li>
              <li>Exposition prolongée au soleil direct</li>
              <li>Produits javel, solvants, nettoyants abrasifs</li>
            </ul>
          </div>
          <div>
            <h3 class="text-cream font-medium mb-1.5">Conseil durabilité</h3>
            <p>Un tapis de souris BuddyPad entretenu correctement dure plusieurs années. Pour préserver la glisse de la surface micro-tissée, évitez de poser des boissons ou des aliments dessus, et nettoyez les taches dès leur apparition.</p>
          </div>
        </div>
      </details>
    </section>

  </div>

  <!-- ═══════════════════════════ FABRICATION HAUTE PRÉCISION ═══════════════════════════ -->
  <FabricationSection />

  <!-- ═══════════════════════════ VOUS AIMEREZ AUSSI (slider full-width) ═══════════════════════════ -->
  {related.length > 0 && (
    <section class="relative py-16 md:py-20 border-t border-white/[0.04] overflow-hidden">
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="flex items-end justify-between mb-6 md:mb-8 gap-4">
          <div>
            <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-2 block">Collection</span>
            <h2 class="text-xl md:text-2xl font-medium tracking-tight text-cream">Vous aimerez aussi</h2>
          </div>
          <a href={`/product-category/${preferredCategory}`} class="inline-flex items-center gap-1.5 text-xs md:text-sm text-n-400 hover:text-cream transition-colors whitespace-nowrap">
            Voir tout ({related.length})
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>

      <!-- Slider full-width : même structure que la home -->
      <div class="product-slider relative" data-slider>
        <div class="slider-track flex gap-3 md:gap-4 lg:gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 pl-6 md:pl-[max(1.5rem,calc((100vw-80rem)/2+1.5rem))] pr-6">
          {related.map(p => (
            <a
              href={`/product/${p.slug}`}
              class="slider-card group flex-none w-[72vw] sm:w-[45vw] md:w-[30vw] lg:w-[22vw] xl:w-[310px] snap-start block"
            >
              <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-panel border border-white/[0.05] mb-3">
                <img
                  src={p.data.image}
                  srcset={unsplashSrcset(p.data.image)}
                  sizes="(max-width: 640px) 72vw, (max-width: 768px) 45vw, (max-width: 1024px) 32vw, 300px"
                  alt={p.data.imageAlt ?? p.data.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="800" height="600" loading="lazy" decoding="async"
                />
                {p.data.compareAtPrice && (
                  <span class="absolute top-3 left-3 bg-cream text-dark text-[10px] font-medium px-2 py-1 rounded-sm uppercase tracking-wider">
                    -{Math.round((1 - p.data.price / p.data.compareAtPrice) * 100)}%
                  </span>
                )}
              </div>
              <h3 class="text-sm font-medium text-cream tracking-tight leading-snug line-clamp-2 mb-1 group-hover:underline underline-offset-4">
                {p.data.name}
              </h3>
              <div class="flex items-baseline gap-2 text-xs">
                <span class="text-cream font-medium">
                  {p.data.priceRange && p.data.priceRange.min !== p.data.priceRange.max
                    ? `Dès ${formatPrice(p.data.priceRange.min)}`
                    : formatPrice(p.data.price)}
                </span>
                {p.data.compareAtPrice && (
                  <span class="text-n-500 line-through font-light">{formatPrice(p.data.compareAtPrice)}</span>
                )}
              </div>
            </a>
          ))}
          <div class="flex-none w-2" aria-hidden="true"></div>
        </div>

        <!-- Flèches desktop -->
        <div class="pointer-events-none absolute inset-0 max-w-7xl mx-auto hidden md:block px-6">
          <button
            type="button"
            data-scroll="prev"
            class="pointer-events-auto absolute left-2 top-[38%] -translate-y-1/2 w-10 h-10 rounded-full bg-dark/90 border border-white/[0.15] backdrop-blur flex items-center justify-center text-cream hover:bg-dark hover:border-white/30 disabled:opacity-0 disabled:pointer-events-none transition-all shadow-lg"
            aria-label="Produits précédents"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button
            type="button"
            data-scroll="next"
            class="pointer-events-auto absolute right-2 top-[38%] -translate-y-1/2 w-10 h-10 rounded-full bg-dark/90 border border-white/[0.15] backdrop-blur flex items-center justify-center text-cream hover:bg-dark hover:border-white/30 disabled:opacity-0 disabled:pointer-events-none transition-all shadow-lg"
            aria-label="Produits suivants"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <style>
        .product-slider .slider-track { scrollbar-width: none; -ms-overflow-style: none; }
        .product-slider .slider-track::-webkit-scrollbar { display: none; }
        /* Galerie : masque scrollbar horizontale sur le track */
        .gallery-track { scrollbar-width: none; -ms-overflow-style: none; }
        .gallery-track::-webkit-scrollbar { display: none; }
        /* Toggles produit : masque le marker natif des <summary> */
        .product-toggle summary::-webkit-details-marker { display: none; }
        .product-toggle summary::marker { content: ''; }
      </style>
    </section>
  )}

  <!-- ═══════════════════════════ JS : VARIANTES + GALERIE ═══════════════════════════ -->
  <script is:inline set:html={`
    (function() {
      /* ─────── Slider "Vous aimerez aussi" (flèches desktop) ─────── */
      document.querySelectorAll('[data-slider]').forEach(slider => {
        const track = slider.querySelector('.slider-track');
        const prev  = slider.querySelector('[data-scroll="prev"]');
        const next  = slider.querySelector('[data-scroll="next"]');
        if (!track) return;
        function scrollBy(dir) {
          const card = track.querySelector('.slider-card');
          if (!card) return;
          const cardWidth = card.getBoundingClientRect().width + 20;
          track.scrollBy({ left: cardWidth * 2 * dir, behavior: 'smooth' });
        }
        prev?.addEventListener('click', () => scrollBy(-1));
        next?.addEventListener('click', () => scrollBy(1));
        function upd() {
          if (!prev || !next) return;
          prev.disabled = track.scrollLeft <= 1;
          next.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 1;
        }
        track.addEventListener('scroll', upd, { passive: true });
        window.addEventListener('resize', upd);
        requestAnimationFrame(upd);
      });

      /* ─────── Galerie (scroll-snap swipe + flèches desktop + thumbs desktop) ─────── */
      const gallery = document.querySelector('[data-gallery]');
      let goToSlide = () => {};

      if (gallery) {
        const track  = gallery.querySelector('[data-gallery-track]');
        const thumbs = Array.from(gallery.querySelectorAll('[data-gallery-thumb]'));
        const prev   = gallery.querySelector('[data-gallery-prev]');
        const next   = gallery.querySelector('[data-gallery-next]');
        const slideCount = parseInt(gallery.dataset.slideCount || '0', 10);
        let current = 0;

        function updateUI() {
          thumbs.forEach((t, i) => {
            t.className = 'gallery-thumb aspect-square rounded-lg overflow-hidden border transition-colors ' + (i === current ? 'border-cream' : 'border-white/[0.08] hover:border-white/30');
          });
          if (prev) prev.disabled = current <= 0;
          if (next) next.disabled = current >= slideCount - 1;
        }

        goToSlide = (idx) => {
          if (idx < 0 || idx >= slideCount || !track) return;
          track.scrollTo({ left: track.clientWidth * idx, behavior: 'smooth' });
        };

        // Détecte le slide courant via scroll (swipe mobile + scrollTo)
        if (track) {
          let rafId = null;
          track.addEventListener('scroll', () => {
            if (rafId) cancelAnimationFrame(rafId);
            rafId = requestAnimationFrame(() => {
              const idx = Math.round(track.scrollLeft / track.clientWidth);
              if (idx !== current) { current = idx; updateUI(); }
            });
          }, { passive: true });
        }

        prev?.addEventListener('click', () => goToSlide(current - 1));
        next?.addEventListener('click', () => goToSlide(current + 1));
        thumbs.forEach((t, i) => t.addEventListener('click', () => goToSlide(i)));

        gallery.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft')  { e.preventDefault(); goToSlide(current - 1); }
          if (e.key === 'ArrowRight') { e.preventDefault(); goToSlide(current + 1); }
        });
        gallery.setAttribute('tabindex', '0');

        updateUI();
      }

      /* ─────── Sélecteur de variantes ─────── */
      const variants = ${variantsJson};
      const buyBtn   = document.getElementById('buy-button') || document.querySelector('.snipcart-add-item');
      const priceEl  = document.getElementById('product-price');
      const compareEl = document.getElementById('product-compare');
      const stockEl  = document.getElementById('product-stock');
      const selector = document.getElementById('variant-selector');
      const currency = '${siteConfig.shop.currency}';

      if (!variants.length || !selector || !buyBtn) return;

      // Slide 0 = image principale (on swap son src à chaque changement de variante).
      // La thumb 0 correspondante est aussi mise à jour.
      const mainSlide = gallery ? gallery.querySelector('[data-gallery-slide="0"]') : null;
      const mainThumb = gallery ? gallery.querySelector('[data-gallery-thumb="0"] img') : null;
      const originalMainSrc = mainSlide ? mainSlide.getAttribute('src') : null;

      // Initial selection = premier bouton actif de chaque attribut
      const selected = {};
      selector.querySelectorAll('[data-attr]').forEach(btn => {
        const attr = btn.dataset.attr;
        if (selected[attr]) return;
        if (btn.classList.contains('bg-cream')) selected[attr] = btn.dataset.value;
      });

      const fmtPrice = (v) => new Intl.NumberFormat('fr-FR', { style: 'currency', currency }).format(v);

      function findVariant() {
        return variants.find(v => {
          for (const [k, val] of Object.entries(selected)) {
            if (v.attributes[k] !== val) return false;
          }
          return true;
        });
      }

      function update() {
        const v = findVariant();

        // Labels "Dimensions : 45 × 35 cm"
        Object.entries(selected).forEach(([attr, slug]) => {
          const label = document.querySelector('[data-selected-label="' + attr + '"]');
          if (label) {
            const pill = selector.querySelector('[data-attr="' + attr + '"][data-value="' + slug + '"]');
            label.textContent = pill ? pill.textContent.trim() : slug;
          }
        });

        if (!v) {
          buyBtn.disabled = true;
          buyBtn.textContent = 'Combinaison indisponible';
          if (stockEl) { stockEl.className = 'flex items-center gap-2 mb-6 text-sm font-light text-n-500'; stockEl.querySelector('span:last-child').textContent = 'Indisponible'; stockEl.querySelector('span:first-child').className = 'w-1.5 h-1.5 rounded-full bg-n-500'; }
          return;
        }

        // Prix / compare / badge
        if (priceEl) priceEl.textContent = fmtPrice(v.price);
        if (compareEl) {
          if (v.compareAtPrice) {
            compareEl.textContent = fmtPrice(v.compareAtPrice);
            compareEl.classList.remove('hidden');
          } else {
            compareEl.classList.add('hidden');
          }
        }

        // Stock
        if (stockEl) {
          if (v.inStock) {
            stockEl.className = 'flex items-center gap-2 mb-6 text-sm font-light text-sage';
            stockEl.querySelector('span:first-child').className = 'w-1.5 h-1.5 rounded-full bg-sage';
            stockEl.querySelector('span:last-child').textContent = 'En stock';
          } else {
            stockEl.className = 'flex items-center gap-2 mb-6 text-sm font-light text-n-500';
            stockEl.querySelector('span:first-child').className = 'w-1.5 h-1.5 rounded-full bg-n-500';
            stockEl.querySelector('span:last-child').textContent = 'Rupture';
          }
        }

        // IMAGE : swap le src du slide principal + thumb 0 sur l'image de la variante
        // (ou revient à l'image originale si la variante n'a pas d'image dédiée)
        if (mainSlide) {
          const nextSrc = v.image || originalMainSrc;
          if (nextSrc && mainSlide.getAttribute('src') !== nextSrc) {
            mainSlide.setAttribute('src', nextSrc);
            mainSlide.removeAttribute('srcset');
            if (mainThumb) mainThumb.setAttribute('src', nextSrc);
          }
          // Toujours ramener l'affichage sur le slide 0 (qui est maintenant l'image variante)
          goToSlide(0);
        }

        // Bouton Atelier
        buyBtn.disabled = !v.inStock;
        buyBtn.dataset.itemId = v.id;
        buyBtn.dataset.itemPrice = Math.round(v.price * 100);
        const variantDesc = Object.entries(selected).map(([k, val]) => {
          const pill = selector.querySelector('[data-attr="' + k + '"][data-value="' + val + '"]');
          return k + ': ' + (pill ? pill.textContent.trim() : val);
        }).join(', ');
        buyBtn.dataset.itemName = ${JSON.stringify(name)} + ' (' + variantDesc + ')';
        if (v.image) buyBtn.dataset.itemImage = v.image;
        buyBtn.textContent = v.inStock ? 'Acheter — ' + fmtPrice(v.price) : 'Indisponible';
      }

      selector.querySelectorAll('[data-variant-option]').forEach(btn => {
        btn.addEventListener('click', () => {
          const attr = btn.dataset.attr;
          selector.querySelectorAll('[data-attr="' + attr + '"]').forEach(b => {
            b.className = 'variant-pill text-xs font-medium px-4 py-2 rounded-full border transition-colors bg-white/[0.02] text-n-400 border-white/[0.08] hover:text-cream hover:border-white/20';
          });
          btn.className = 'variant-pill text-xs font-medium px-4 py-2 rounded-full border transition-colors bg-cream text-dark border-cream';
          selected[attr] = btn.dataset.value;
          update();
        });
      });

      update();
    })();
  `} />
</BaseLayout>
