---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../../site.config.mjs';
import { unsplashSrcset, unsplashAt } from '../lib/image';

const allProducts = await getCollection('products');
const products = allProducts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(products.map(p => p.data.category))];
const featured = products.find(p => p.data.featured);
const rest = products.filter(p => !p.data.featured || p.slug !== featured?.slug);

const formatPrice = (n: number) => new Intl.NumberFormat('fr-FR', { style: 'currency', currency: siteConfig.shop.currency }).format(n);

const SITE_URL = siteConfig.url;
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Boutique ${siteConfig.name}`,
  description: `Tapis de souris gaming, bureautique, XXL et accessoires setup sélectionnés par ${siteConfig.name}.`,
  url: `${SITE_URL}/tapis-de-souris`,
  inLanguage: 'fr-FR',
  isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: SITE_URL },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Boutique', item: `${SITE_URL}/tapis-de-souris` },
  ],
};
---

<BaseLayout
  title={`Boutique ${siteConfig.name} – Tapis de souris & accessoires setup`}
  description={`Notre sélection de tapis de souris gaming, bureautique, XXL et d'accessoires testés pour sublimer votre setup.`}
  jsonLd={[collectionSchema, breadcrumbSchema]}
>
  <section class="max-w-7xl mx-auto px-6 py-16 md:py-24">
    <!-- Page header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div>
        <h1 class="text-3xl md:text-4xl font-medium tracking-tight text-cream mb-2 leading-[1.15]">La Collection</h1>
        <p class="text-sm text-n-500 font-light">Trouvez la surface adaptée à votre style.</p>
      </div>
      <div class="flex items-center gap-2 text-xs text-n-500 font-light">
        <Icon name="shield-check" size={14} strokeWidth={1.5} />
        <span>Livraison dès 49€</span>
        <span class="mx-2">·</span>
        <span>Retour 30 jours</span>
      </div>
    </div>

    {products.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-sm text-n-500 font-light">Les premiers produits arrivent bientôt…</p>
      </div>
    ) : (
      <>
        <!-- Featured product -->
        {featured && (
          <a href={`/product/${featured.slug}`} class="group block mb-16 md:mb-20">
            <div class="grid md:grid-cols-5 gap-8 md:gap-10">
              <div class="md:col-span-3 relative aspect-[16/10] md:aspect-[21/12] rounded-2xl overflow-hidden bg-panel border border-white/[0.05]">
                <img
                  src={unsplashAt(featured.data.image, 800)}
                  srcset={unsplashSrcset(featured.data.image)}
                  sizes="(max-width: 768px) 100vw, 60vw"
                  alt={featured.data.imageAlt ?? featured.data.name}
                  class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                  width="1200" height="675" fetchpriority="high" decoding="async"
                />
                <div class="absolute top-4 left-4">
                  <span class="bg-cream text-dark text-[10px] font-medium px-2 py-1 rounded-sm uppercase tracking-wider">Bestseller</span>
                </div>
              </div>
              <div class="md:col-span-2 flex flex-col justify-center">
                <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-3">{featured.data.category}</span>
                <h2 class="text-2xl md:text-3xl text-cream font-medium tracking-tight leading-tight mb-4 group-hover:underline underline-offset-4">
                  {featured.data.name}
                </h2>
                <p class="text-sm text-n-400 font-light leading-relaxed mb-6">
                  {featured.data.shortDescription}
                </p>
                <div class="flex items-baseline gap-3">
                  <span class="text-2xl text-cream font-medium tracking-tight">{formatPrice(featured.data.price)}</span>
                  {featured.data.compareAtPrice && (
                    <span class="text-sm text-n-500 line-through font-light">{formatPrice(featured.data.compareAtPrice)}</span>
                  )}
                </div>
              </div>
            </div>
          </a>
        )}

        <!-- Category filters -->
        {categories.length > 1 && (
          <div class="flex flex-wrap gap-2 mb-10">
            <button data-filter="all" class="filter-btn text-xs font-medium px-4 py-2 rounded-full bg-cream text-dark transition-colors">
              Tous
            </button>
            {categories.map(cat => (
              <button
                data-filter={cat}
                class="filter-btn text-xs font-medium px-4 py-2 rounded-full border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20 transition-colors"
              >
                {cat}
              </button>
            ))}
          </div>
        )}

        <!-- Products grid -->
        <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {rest.map(product => (
            <a href={`/product/${product.slug}`} class="product-card group block" data-category={product.data.category}>
              <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-panel border border-white/[0.05] mb-5">
                <img
                  src={unsplashAt(product.data.image, 600)}
                  srcset={unsplashSrcset(product.data.image, [400, 600, 800])}
                  sizes="(max-width: 768px) calc(100vw - 32px), (max-width: 1024px) calc(50vw - 48px), 380px"
                  alt={product.data.imageAlt ?? product.data.name}
                  class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                  width="800" height="600" loading="lazy"
                />
                {product.data.compareAtPrice && (
                  <div class="absolute top-4 left-4">
                    <span class="bg-cream text-dark text-[10px] font-medium px-2 py-1 rounded-sm uppercase tracking-wider">Promo</span>
                  </div>
                )}
              </div>
              <div class="flex justify-between items-start gap-4">
                <div class="min-w-0">
                  <h2 class="text-base font-medium text-cream mb-1 tracking-tight group-hover:underline underline-offset-4 truncate">
                    {product.data.name}
                  </h2>
                  <p class="text-xs text-n-500 font-light truncate">{product.data.shortDescription}</p>
                </div>
                <div class="flex items-baseline gap-2 shrink-0">
                  <span class="text-sm text-cream font-medium">{formatPrice(product.data.price)}</span>
                  {product.data.compareAtPrice && (
                    <span class="text-xs text-n-500 line-through font-light">{formatPrice(product.data.compareAtPrice)}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </section>
</BaseLayout>

<script is:inline>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const f = btn.getAttribute('data-filter');
      filterBtns.forEach(b => {
        b.classList.remove('bg-cream', 'text-dark');
        b.classList.add('border', 'border-white/[0.08]', 'bg-white/[0.02]', 'text-n-400');
      });
      btn.classList.add('bg-cream', 'text-dark');
      btn.classList.remove('border', 'border-white/[0.08]', 'bg-white/[0.02]', 'text-n-400');
      cards.forEach(c => {
        const match = f === 'all' || c.getAttribute('data-category') === f;
        c.style.display = match ? '' : 'none';
      });
    });
  });
</script>
